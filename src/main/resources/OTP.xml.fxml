<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: white;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.OtpController">
    <children>
        <VBox alignment="CENTER" layoutX="100.0" layoutY="50.0" prefHeight="400.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-background-radius: 10;">
            <children>
                <Label text="Xác Thực OTP" textFill="#2d3436">
                    <font>
                        <Font name="Segoe UI Bold" size="24.0" />
                    </font>
                </Label>

                <Label fx:id="messageLabel" text="Chúng tôi đã gửi mã xác thực đến email..." textAlignment="CENTER" textFill="#636e72" wrapText="true">
                    <font>
                        <Font name="Segoe UI" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="otpTextField" alignment="CENTER" maxWidth="250.0" promptText="Nhập mã OTP" style="-fx-background-color: #f1f2f6; -fx-background-radius: 5; -fx-padding: 10; -fx-font-size: 18px; -fx-font-weight: bold;">
                    <font>
                        <Font name="Segoe UI Bold" size="18.0" />
                    </font>
                </TextField>

                <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#onConfirmClick" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="XÁC NHẬN">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Chưa nhận được mã?" textFill="#636e72" />
                        <Hyperlink fx:id="resendLink" onAction="#onResendClick" text="Gửi lại (60s)" textFill="#0984e3" underline="true" />
                    </children>
                </HBox>

                <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Quay lại Đăng ký" textFill="#b2bec3" underline="true" />
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>