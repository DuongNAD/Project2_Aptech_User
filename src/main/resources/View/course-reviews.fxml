<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.FlowPane?>

<VBox fx:id="rootPane" prefHeight="768.0" prefWidth="1024.0" spacing="20.0"
      style="-fx-background-color: #F7F9FC;"
      stylesheets="@/Css/courses.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.CoursesController">

    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="modern-header">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>
            <children>
                <VBox>
                    <Label text="Khám phá khóa học" styleClass="header-title"/>
                    <Label text="Hôm nay bạn muốn học gì?" styleClass="header-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" styleClass="modern-search-bar" prefWidth="350.0">
                    <ImageView fitHeight="18.0" fitWidth="18.0" opacity="0.4">
                        <Image url="https://img.icons8.com/ios-glyphs/30/000000/search--v1.png" />
                    </ImageView>
                    <TextField promptText="Tìm kiếm..." styleClass="search-field-transparent" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER" spacing="15.0">

                    <Button fx:id="themeBtn" styleClass="btn-icon-gray" onAction="#toggleTheme">
                        <graphic>
                            <ImageView fx:id="themeIcon" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="https://img.icons8.com/ios-glyphs/30/000000/moon-symbol.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button styleClass="btn-icon-gray" text="🔔" />

                    <HBox alignment="CENTER" spacing="10.0" styleClass="user-badge">
                        <ImageView fx:id="userAvatar" fitHeight="32.0" fitWidth="32.0">
                            <image><Image url="https://i.pravatar.cc/150?img=12" /></image>
                            <clip><Circle centerX="16" centerY="16" radius="16" /></clip>
                        </ImageView>
                        <Label fx:id="userNameLabel" text="Đang tải" style="-fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                    </HBox>
                </HBox>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 0 30;">
            <HBox fx:id="chipsContainer" spacing="10.0" alignment="CENTER_LEFT"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Danh mục khác:" style="-fx-text-fill: #718096; -fx-font-weight: bold;"/>
                <ComboBox fx:id="categoryComboBox" promptText="Chọn danh mục..."
                          styleClass="modern-combo-box" prefWidth="180"/>
            </HBox>
        </HBox>

        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="coursesContainer"
                          hgap="20.0" vgap="20.0"
                          prefWrapLength="1100.0"
                          style="-fx-padding: 10 30 30 30;">
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</VBox>