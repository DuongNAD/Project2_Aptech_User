            </VBox>

            <VBox style="-fx-border-color: #D1D7DC; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Circle radius="20.0" style="-fx-fill: #5624d0;" />
                        <VBox>
                            <Label text="Lê Thị C" style="-fx-font-weight: bold;" />
                            <HBox spacing="10">
                                <Label text="★★★★☆" style="-fx-text-fill: #F7C32E;" />
