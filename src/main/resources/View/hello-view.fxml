<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1280.0" stylesheets="@/Css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.HelloController">

    <left>
        <StackPane fx:id="sidebar" alignment="CENTER_RIGHT">

            <VBox prefWidth="260.0" spacing="15.0" styleClass="sidebar">
                <children>
                    <VBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-padding: 0 0 0 25;">
                        <children>
                            <Label styleClass="logo-label" text="EduPath" />
                            <Label style="-fx-text-fill: #718096; -fx-font-size: 12px; -fx-font-weight: bold;" text="System" />
                        </children>
                    </VBox>

                    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <children>
                            <Button fx:id="homeBtn" maxWidth="Infinity" styleClass="nav-btn, nav-btn-active" text="🏠   Trang chủ" />
                            <Button fx:id="myCoursesBtn" maxWidth="Infinity" styleClass="nav-btn" text="📚   Khóa học của tôi" />
                            <Button fx:id="shopBtn" maxWidth="Infinity" styleClass="nav-btn" text="🛒   Cửa hàng" />
                            <Button fx:id="statisticsBtn" maxWidth="Infinity" styleClass="nav-btn" text="📊   Thống kê" />

                            <VBox VBox.vgrow="ALWAYS" /> <Separator style="-fx-opacity: 0.2; -fx-background-color: #A0AEC0;" />
                            <Button fx:id="settingsBtn" maxWidth="Infinity" styleClass="nav-btn" text="⚙   Cài đặt" />
                            <Button fx:id="logoutBtn" maxWidth="Infinity" style="-fx-text-fill: #FC8181;" styleClass="nav-btn" text="🚪   Đăng xuất" />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <Button onAction="#closeSidebar" styleClass="btn-sidebar-close" text="❮" />

        </StackPane>
    </left>

    <center>
        <VBox>

            <StackPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS">

                <fx:include source="courses.fxml" />

                <Button fx:id="btnOpenSidebar" managed="false" onAction="#openSidebar"
                        styleClass="btn-floating-open" text="❯" visible="false"
                        StackPane.alignment="BOTTOM_LEFT">
                    <StackPane.margin>
                        <Insets bottom="20.0" left="20.0" /> </StackPane.margin>
                </Button>

            </StackPane>
        </VBox>
    </center>

</BorderPane>